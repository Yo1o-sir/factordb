#!/usr/bin/env python
import sys

import requests

if len(sys.argv) != 2:
    print("Usage: factordb <number>")
    sys.exit(1)
n = sys.argv[1]
url = f"https://factordb.com/api?query={n}"
try:
    r = requests.get(url, timeout=10)
    data = r.json()
except Exception as e:
    print(f"Error: {e}")
    sys.exit(1)

status = data.get("status")
factors = data.get("factors", [])

if status != "FF":
    print("factordb wrong")
    sys.exit(0)

expanded = []
for f, exp in factors:
    expanded += [f] * exp

if len(expanded) == 2:
    p, q = expanded
    print(f"p={p}\nq={q}")
else:
    expr = " * ".join([f"{f}^{exp}" if exp > 1 else f for f, exp in factors])
    print(f"factors: {expr}")
